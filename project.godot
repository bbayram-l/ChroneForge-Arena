; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ChronoForge Arena"
config/description="A deterministic, grid-based roguelike auto-battler. Build unstable modular mechs. Break physics. Bend time. Out-engineer reality."
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoload/GameState.gd"
ModuleRegistry="*res://scripts/autoload/ModuleRegistry.gd"
GameLogger="*res://scripts/autoload/Logger.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=800
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="mobile"
